AGENT_PLAYGROUND_DATABASE_URL=sqlite+aiosqlite:///./agent_playground.db
AGENT_PLAYGROUND_MODEL_PROVIDER=fake
AGENT_PLAYGROUND_MAX_AGENT_LOOPS=4
AGENT_PLAYGROUND_LLM_TIMEOUT_SECONDS=60
AGENT_PLAYGROUND_LLM_MAX_RETRIES=2

# 设置为 claude 后，将通过官方 Anthropic SDK 读取真实 LLM。
# 推荐把 API Key 放在本地 .env 或系统环境变量，不要提交到仓库。
# AGENT_PLAYGROUND_MODEL_PROVIDER=claude
# AGENT_PLAYGROUND_ANTHROPIC_API_KEY=sk-ant-...
AGENT_PLAYGROUND_CLAUDE_MODEL=claude-opus-4-8
AGENT_PLAYGROUND_CLAUDE_MAX_TOKENS=16000
AGENT_PLAYGROUND_CLAUDE_EFFORT=medium
# disabled | adaptive
AGENT_PLAYGROUND_CLAUDE_THINKING=adaptive

# OpenAI / OpenAI-compatible provider
# AGENT_PLAYGROUND_MODEL_PROVIDER=openai
# AGENT_PLAYGROUND_OPENAI_API_KEY=sk-...
AGENT_PLAYGROUND_OPENAI_MODEL=gpt-4.1
# AGENT_PLAYGROUND_OPENAI_BASE_URL=https://api.openai.com/v1
AGENT_PLAYGROUND_OPENAI_MAX_TOKENS=16000
# max_completion_tokens | max_tokens；部分 OpenAI-compatible 服务只支持 max_tokens。
AGENT_PLAYGROUND_OPENAI_TOKEN_PARAMETER=max_completion_tokens
# auto 会在自定义 OpenAI-compatible base_url 下自动启用协议兼容模式：使用 max_tokens，并改用宽松流式解析。
AGENT_PLAYGROUND_OPENAI_PROTOCOL_MODE=auto
# 旧字段，仍兼容读取；新配置请改用 AGENT_PLAYGROUND_OPENAI_PROTOCOL_MODE。
# AGENT_PLAYGROUND_OPENAI_COMPATIBILITY_MODE=auto
# 设为 false 可显式禁用 Chat Completions tool calling；协议兼容模式不会再自动关闭 tools。
AGENT_PLAYGROUND_OPENAI_TOOL_CALLING=true
# 某些 OpenAI-compatible 网关会拦截缺少浏览器 UA 的请求，可按需覆盖或留空禁用。
AGENT_PLAYGROUND_OPENAI_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
